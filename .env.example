# Reference only — Angular does not load this file during `ng serve` or in the browser.
# Copy values here into the right place (see README "Configuration").
#
# ---------------------------------------------------------------------------
# Docker / Coolify — build-time (see Dockerfile)
# Either name works; API_URL wins if both are set (Angular naming vs legacy Vite).
#   docker build --build-arg API_URL=https://api.yourdomain.com -t staff-ui .
#   docker build --build-arg VITE_API_URL=https://api.yourdomain.com -t staff-ui .
# ---------------------------------------------------------------------------
API_URL=https://api.yourdomain.com
# VITE_API_URL=https://api.yourdomain.com

# ---------------------------------------------------------------------------
# Local development — edit source instead of relying on .env:
#   src/environments/environment.development.ts
# Default backend URL in environment files: http://localhost:3001
# ---------------------------------------------------------------------------
# DEV_API_URL=http://localhost:3001
